rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ajjubhaifree4@gmail.com' || 
        request.auth.token.email == 'jaidwivediofficial@gmail.com'
      );
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) 
        && request.resource.data.userId == userId
        && request.resource.data.balance == 499;
      allow update: if isOwner(userId) 
        && request.resource.data.balance == resource.data.balance;
    }

    match /users/{userId}/history/{transactionId} {
      allow list, get: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /redemptions/{redemptionId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'PENDING';
      allow update, delete: if isAdmin();
    }
  }
}
